# ─── BR10 Network Manager - Variáveis de Ambiente ────────────────────────────
# Copie este arquivo para .env e preencha os valores

# ─── Banco de Dados PostgreSQL ────────────────────────────────────────────────
DB_NAME=br10netmanager
DB_USER=br10user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Segurança (gere com: openssl rand -hex 32) ───────────────────────────────
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ─── Aplicação ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://br10web.br10consultoria.com.br
ENVIRONMENT=production
LOG_LEVEL=INFO

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_API_KEY=CHANGE_ME_BACKUP_API_KEY

# ─── Domínio ──────────────────────────────────────────────────────────────────
DOMAIN=br10web.br10consultoria.com.br
